{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/site.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }]
    }
  ],
  "rewrites": [
    { "source": "/order", "destination": "/order.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/confirmation", "destination": "/confirmation.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/admin/login", "destination": "/admin/login.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/customer-portal", "destination": "/portal/login.html" },
    { "source": "/portal/login", "destination": "/portal/login.html" },
    { "source": "/portal/register", "destination": "/portal/register.html" },
    { "source": "/portal", "destination": "/portal/index.html" }
  ]
}
